# Copy this file to .env and adjust as needed. Do NOT commit your .env file.
# Every value below is optional — MoneyFlow runs with zero configuration using a
# local SQLite database and with AI disabled.

# --- Database ---------------------------------------------------------------
# Default (unset): a local SQLite file at data/moneyflow.db.
# For PostgreSQL, install the "postgres" extra and set a URL, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/moneyflow
# DATABASE_URL=

# --- Application ------------------------------------------------------------
# MONEYFLOW_DATA_DIR=data
# MONEYFLOW_DEBUG=false
# MONEYFLOW_CURRENCY_SYMBOL=£
# MONEYFLOW_DAILY_CSV_LIMIT=10

# --- AI provider (optional) -------------------------------------------------
# One of: none (default) | local | openai
# MONEYFLOW_AI_PROVIDER=none

# Model identifier (HuggingFace repo for 'local', model name for 'openai').
# MONEYFLOW_AI_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# For MONEYFLOW_AI_PROVIDER=openai (any OpenAI-compatible endpoint, e.g. Ollama,
# LM Studio, llama.cpp, vLLM, or a hosted service):
# MONEYFLOW_AI_BASE_URL=http://localhost:11434/v1
# MONEYFLOW_AI_API_KEY=
# MONEYFLOW_AI_TIMEOUT=60
# MONEYFLOW_AI_MAX_TOKENS=512
# MONEYFLOW_AI_TEMPERATURE=0.7
